    "true_p1_incidents": [
      {
        "reference": "INC-8041",
        "name": "Issues with segments having singularity features due to crm-api errors",
        "status": "Closed",
        "reported_at": "2026-05-26T12:34:10Z",
        "cause": "FT - Backend Code Defect",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8041",
        "summary": "Problem: Partners were unable to create, update, or clone segments using singularity features with specific operators in crm-api versions 2.61.26 and 2.61.27, causing crm-api errors.\n\nImpact: 88 out of 119 production brands (73%) were unable to create, update, or clone segments that use singularity features with operators such as \"equals\", \"contains\", or \"not contains\". Multiclass features were unaffected.\n\nCause: A bug introduced by PR #2250 in crm-api versions 2.61.26\u20132.61.27 caused errors when segments used singularity features with certain operators.\n\nResolution: The backend fix was merged and deployed to all impacted brands (platform v2.61.30). Partner communications sent. No customer action required."
      },
      {
        "reference": "INC-8064",
        "name": "[P1] Intercom Incident : H2Bet Production",
        "status": "Waiting on Partner",
        "reported_at": "2026-05-26T15:47:42Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8064",
        "summary": "Problem: Duplicate bonus sends occurred in H2Bet production, resulting in users getting more than one bonus when only one was intended. This issue has been ongoing for at least 24 weeks and includes both ongoing and acute cases.\n\nImpact: Between 275 and 936 users per week in H2Bet production have received duplicate or multiple bonuses instead of one over the past 24 weeks. On 25 May 2026, 26 H2Bet players received the same bonus 2\u20133 times in a single day. Users affected may have received unintentional extra credits.\n\nCauses: Repeated retries against operator 503 errors led to multiple bonuses being granted on the operator side, despite only a single intended bonus dispatch per user. This was due to insufficient idempotency handling in the bonus distribution system. Additionally, some 503 responses were returned after the bonus was already credited, causing FastTrack's system to retry and create duplicates. A separate stream of duplicate bonuses, unrelated to this flow, also exists and requires further investigation.\n\nSteps to resolve: We have created a proposed fix (PR #122) to improve idempotency handling in the bonus distribution system. The change is under review. The client rejected a workaround to treat BetConstruct 503 responses as successful due to traceability concerns and requested more analysis, pre-retry verification, and a long-term fix from BetConstruct. Action items are in progress to provide data extracts and coordinate with BetConstruct for a permanent solution."
      },
      {
        "reference": "INC-8219",
        "name": "Spinbet Investigation",
        "status": "Fixing",
        "reported_at": "2026-05-28T13:10:23Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8219",
        "summary": "Problem: A security breach of Spinbet's SendGrid account required urgent action, which disrupted all email services for both Spinbet and Razed.\n\nImpact: Email sending for both Spinbet and Razed has been fully disrupted since the credentials were removed, resulting in all outgoing emails failing to send for both brands. Additional work is now needed to rotate all external-facing API keys for affected integrations.\n\nCauses: Spinbet's SendGrid account was breached. Both Spinbet and Razed were using the same SendGrid key, which caused email failures in both environments once the credentials were disabled.\n\nSteps to resolve: We locked the affected environments, scaled down email distribution, and removed the compromised SendGrid credentials to contain the breach. We are working with the partner to support setup and integration of an alternative email provider for both environments. We have started the process to rotate all external-facing API keys, and credentials are being securely shared via 1Password."
      }
    ]
  },
  "2026-06-01": {
    "p1_quality_incidentio": {
      "true_p1": 2,
      "false_p1": 1,
      "unclassified": 1
    },
    "true_p1_incidents": [
      {
        "reference": "INC-8611",
        "name": "[P1] Intercom Incident : Lottogo Production",
        "status": "Closed",
        "reported_at": "2026-06-03T14:31:46Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8611",
        "summary": "Problem: Email templates were not visible to partners using custom user roles in Lottogo Production, preventing access needed for ongoing operations.\n\nImpact: Partners using custom user roles in Lottogo Production could not view email templates, impacting their ability to manage live lifecycle communications. The affected partner confirmed resolution once the fix was applied.\n\nCauses: A backend code defect in crm-api permissions affected partners using custom user roles, following a recent switch to an origin-based setup.\n\nSteps to resolve: We added the brand ID to the correct Unleash segment and restarted the crm-api pods, restoring access to the templates. The partner confirmed the issue was fixed and the related Intercom ticket was closed."
      },
      {
        "reference": "INC-8571",
        "name": "[P1] Intercom Incident : Galabet Production",
        "status": "Waiting on Partner",
        "reported_at": "2026-06-02T21:38:38Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8571",
        "summary": "Problem: The 'My Rewards' button is missing for most Galabet player and internal accounts, although reward events are still firing and visible in Fast Track.\n\nImpact: Most Galabet player and internal accounts are unable to see the 'My Rewards' button, which prevents them from accessing their rewards. The partner has paused the rewards campaign as a result.\n\nCauses: A load-order issue in BetConstruct's FastTrack integration caused FasttrackCrm.init() to be called before the CRM SDK was loaded. This resulted in a silent failure of initialization and prevented authentication. The same issue affected padisahbet, where the fix is to wait for window.FasttrackCrm before calling init().\n\nSteps to resolve: We have confirmed the root cause and informed the operator of the technical fix. The incident remains open while we wait for the operator to apply the fix for Galabet."
      }
    ],
