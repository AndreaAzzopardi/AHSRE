    "true_p1_incidents": [
      {
        "reference": "INC-8041",
        "name": "Issues with segments having singularity features due to crm-api errors",
        "status": "Closed",
        "reported_at": "2026-05-26T12:34:10Z",
        "cause": "FT - Backend Code Defect",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8041",
        "summary": "Problem: Partners were unable to create, update, or clone segments using singularity features with specific operators in crm-api versions 2.61.26 and 2.61.27, causing crm-api errors.\n\nImpact: 88 out of 119 production brands (73%) were unable to create, update, or clone segments that use singularity features with operators such as \"equals\", \"contains\", or \"not contains\". Multiclass features were unaffected.\n\nCause: A bug introduced by PR #2250 in crm-api versions 2.61.26\u20132.61.27 caused errors when segments used singularity features with certain operators.\n\nResolution: The backend fix was merged and deployed to all impacted brands (platform v2.61.30). Partner communications sent. No customer action required."
      },
      {
        "reference": "INC-8064",
        "name": "[P1] Intercom Incident : H2Bet Production",
        "status": "Monitoring",
        "reported_at": "2026-05-26T15:47:42Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8064",
        "summary": "Problem: Duplicate bonus grants have been observed in H2Bet Production, where BetConstruct returns HTTP 503 responses after a bonus has already been credited on their side, causing Fast Track to retry and grant the same bonus multiple times.\n\nImpact: H2Bet has experienced an average of around 500 extra bonus grants per week over the past 24 weeks, mainly affecting FreeSpin bonuses and more recently Cash bonuses. This pattern has resulted in recurring bonus leakage and unintended duplicate awards to users.\n\nCauses: The main cause is BetConstruct returning a 503 error even after successfully crediting bonuses on their side, which causes Fast Track's Bonus Distributor to retry and create duplicates. This is not the expected behaviour from the operator API.\n\nSteps to resolve: We have completed analysis showing weekend monitoring detected no new duplicate credits despite two BetConstruct 5xx error bursts. Improved observability now allows rapid detection of any new duplications. The root cause is still unresolved on BetConstruct's side \u2014 we are awaiting their feedback and continuing to monitor closely. A May UserID/BonusID extract will be shared with H2Bet so they can assess business impact."
      },
      {
        "reference": "INC-8219",
        "name": "Spinbet Investigation",
        "status": "Monitoring",
        "reported_at": "2026-05-28T13:10:23Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8219",
        "summary": "Problem: Spinbet's SendGrid account was breached, requiring immediate containment action. As part of the response, the compromised SendGrid credentials were removed, which disrupted email sending for both Spinbet and Razed.\n\nImpact: Email sending is currently disrupted for both Spinbet and Razed, with outgoing emails failing after the shared SendGrid credentials were disabled. Both environments were affected because they were using the same SendGrid key. Additional follow-up work is required to rotate external-facing API keys for affected integrations.\n\nCauses: The root cause was a breach of Spinbet's SendGrid account. Since the same SendGrid credentials were being used across both Spinbet and Razed, removing the compromised key to contain the security risk caused email sending failures in both environments. Our internal investigation found no indication of an active security threat within Fast Track.\n\nSteps to resolve: We locked the affected environments, scaled down email distribution, and removed the compromised SendGrid credentials to contain the immediate security risk. We are working with the partner to support the setup of an alternative email provider for both Spinbet and Razed. In parallel, we have started rotating all relevant external-facing API keys, with credentials being shared securely via 1Password. The incident remains in monitoring."
      }
    ]
  },
  "2026-06-01": {
    "p1_quality_incidentio": {
      "true_p1": 2,
      "false_p1": 2,
      "unclassified": 0
    },
    "true_p1_incidents": [
      {
        "reference": "INC-8611",
        "name": "[P1] Intercom Incident : Lottogo Production",
        "status": "Closed",
        "reported_at": "2026-06-03T14:31:46Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8611",
        "summary": "Problem: After enabling the crm-api-enforce-endpoint-permissions feature flag in production, partners (notably Lottogo and Coinbar) reported CRM access issues including missing email template versions and searches by ID returning no results.\n\nImpact: Affected partners were unable to access or retrieve certain CRM data as expected, disrupting workflows like viewing email templates and managing live lifecycles. Reports suggested the issue affected multiple brands, though it wasn't confirmed as universal.\n\nCauses: The rollout introduced stricter CRM API endpoint permissions that didn't account for some brands using special/custom user roles. Those roles were not included in the initial Unleash exclusion segment, so access to certain endpoints was unintentionally blocked when the flag became active.\n\nSteps to resolve: Responders mitigated by adding the affected brand ID(s) to the appropriate Unleash segment and restarting the crm-api pods, then disabled the feature flag as a rollback to restore prior permission behavior. The partner confirmed functionality was restored, and follow-up work was noted to validate missed roles/brands and update the segment before attempting another rollout."
      },
      {
        "reference": "INC-8571",
        "name": "[P1] Intercom Incident : Galabet Production",
        "status": "Monitoring",
        "reported_at": "2026-06-02T21:38:38Z",
        "permalink": "https://app.incident.io/fasttrack-solutions/incidents/8571",
        "summary": "Problem: The My Rewards button intermittently fails to appear for some users on Galabet's frontend, affecting their ability to access rewards.\n\nImpact: A subset of Galabet users were unable to consistently see and use the My Rewards button due to intermittent display failures. The issue affected user engagement with the rewards feature on Galabet Production.\n\nCauses: A race condition in BetConstruct's frontend integration prevented the My Rewards button from rendering reliably for some users.\n\nSteps to resolve: We confirmed the root cause and shared the proposed fix with BetConstruct for implementation. We are monitoring the partner-side rollout and continuing observation; the fix has not yet been fully deployed and the incident remains in monitoring."
      }
    ],
